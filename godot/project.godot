; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="First Project"
run/main_scene="res://main_scene.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/mode=3
window/size/borderless=true
mouse_cursor/custom_image="res://cursor.svg"

[dotnet]

project/assembly_name="First Project"

[layer_names]

2d_render/layer_1="player"
2d_render/layer_2="bullet"
2d_render/layer_3="tiny_meteor"
2d_render/layer_4="normal_meteor"
2d_render/layer_5="big_meteor"

[physics]

2d/default_gravity_vector=Vector2(0, 0)

[rendering]

environment/defaults/default_clear_color=Color(0, 0, 0, 1)
